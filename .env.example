# =============================================================================
# Status Monitor (Uptime Kuma) - Environment Configuration
# =============================================================================
# Self-hosted status & uptime monitoring, powered by Uptime Kuma, wrapped as a
# thin BAUER GROUP edition image with full CI/CD automation.
#
# NO SECRETS REQUIRED. Uptime Kuma has no bootstrap credentials: the admin
# account is created interactively in the web setup wizard on first start and
# is persisted in the data volume. So there is nothing to generate — just:
#
#   cp .env.example .env        (Linux/macOS)
#   Copy-Item .env.example .env (Windows PowerShell)
#
# then review the hostnames / ports below. The CHANGE_ME convention used by the
# other Container-Solution stacks is intentionally absent here.
#
# Deployment:
#   Development (local build): docker compose -f docker-compose.development.yml up -d --build
#   Single (direct port):      docker compose -f docker-compose.single.yml      up -d
#   Traefik (HTTPS + LE):      docker compose -f docker-compose.traefik.yml     up -d
#   Coolify:                   configure env in dashboard -> docker-compose.coolify.yml
# =============================================================================


# =============================================================================
# Stack Configuration
# =============================================================================

# Container / volume / network name prefix
STACK_NAME=status_example_domain_com

# Container timezone (e.g. Europe/Berlin, Etc/UTC). Affects log timestamps and
# the internal scheduler; the dashboard also has its own display-timezone setting.
TIME_ZONE=Etc/UTC


# =============================================================================
# Image Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Production image (pre-built from GHCR) — single / traefik / coolify
# This is OUR published edition image, not the upstream one.
# -----------------------------------------------------------------------------
STATUS_MONITOR_IMAGE=ghcr.io/bauer-group/cs-statusmonitor/status-monitor
STATUS_MONITOR_IMAGE_VERSION=latest

# -----------------------------------------------------------------------------
# Build base (development build) — Uptime Kuma upstream image the edition wraps
# -----------------------------------------------------------------------------
UPTIME_KUMA_REPOSITORY=louislam/uptime-kuma
# Floating tag: tracks the latest Uptime Kuma 2.x. Major is pinned to 2 to avoid
# a breaking jump to 3.x; the base-image monitor rebuilds when its digest moves.
# Pin to an exact tag (e.g. 2.0.0) only if you need reproducibility.
UPTIME_KUMA_VERSION=2


# =============================================================================
# Application Settings
# =============================================================================
# Uptime Kuma is lightweight — RAM/CPU scale with the number of monitors and
# their check interval, not with traffic. A few hundred monitors run comfortably
# in well under 512 MB. No sizing presets are needed (unlike the broker stacks).

# Bind address INSIDE the container. Upstream default is "::" (dual-stack, also
# accepts IPv4). Set to 0.0.0.0 if your host has IPv6 disabled and binding fails.
UPTIME_KUMA_HOST=::

# WebSocket ORIGIN check. The dashboard talks to the backend over socket.io and
# verifies the browser Origin header matches the server hostname.
#   cors-like (default) — secure; works behind Traefik/Coolify when the Host
#                         header is forwarded correctly (it is, by default)
#   bypass              — disable the check; last resort if the live dashboard
#                         shows "Disconnected" behind an unusual proxy setup
UPTIME_KUMA_WS_ORIGIN_CHECK=cors-like

# Allow the dashboard / status pages to be embedded in an <iframe> on another
# domain. false (default) = same-origin only. Set true to embed status pages
# in an external portal.
UPTIME_KUMA_DISABLE_FRAME_SAMEORIGIN=false


# =============================================================================
# Port Settings (development / single — direct host binding)
# =============================================================================
# Host port -> container 3001. Traefik/Coolify modes do not publish this; they
# route to the container port internally.
PORT_HTTP=3001


# =============================================================================
# Traefik Configuration (docker-compose.traefik.yml)
# =============================================================================
# DNS must resolve to this host before starting (Let's Encrypt HTTP-01 challenge).

# Public hostname of the status page / dashboard (served over HTTPS by Traefik)
SERVICE_HOSTNAME=status.example.domain.com

# External Traefik network name (must already exist)
PROXY_NETWORK=EDGEPROXY


# =============================================================================
# Coolify (docker-compose.coolify.yml)
# =============================================================================
# Set the per-service Domain in the Coolify dashboard (Service -> Configuration):
#   status-monitor -> Domain = https://${SERVICE_HOSTNAME}   Port = 3001
# Coolify generates the Traefik routers and manages TLS automatically; this file
# only needs STACK_NAME, TIME_ZONE and the application settings above.
