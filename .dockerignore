# =============================================================================
# Docker Ignore - Root Level
# =============================================================================
# The image is built from ./src/uptime-kuma (see its own .dockerignore). This
# root file guards against an accidental root-context build pulling in repo meta.

.git
.gitignore
.gitattributes
.github
.vscode
.idea
.claude
.DS_Store
Thumbs.db

*.md
LICENSE
CHANGELOG.md

.env
.env.*
!.env.example

docker-compose*.yml
docs
