# =============================================================================
# Git Ignore Configuration
# =============================================================================

# Environment (may contain hostnames / deployment-specific values)
.env
.env.*
.env.bak
!.env.example

# IDE
.vscode/
.idea/
.claude/
*.code-workspace
.history/

# OS Files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Logs
*.log
logs/

# Temporary Files
*.tmp
*.temp
*.bak
*~

# Local Uptime Kuma data (only ever created by accident — the real data lives
# in the named Docker volume, never in the repo)
data/

# Terraform / OpenTofu (infrastructure/cloudflare) — never commit state or vars,
# but DO commit .terraform.lock.hcl (pins provider versions) and *.tfvars.example
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
override.tf
override.tf.json
crash.log
